<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:Noeud.Presentation"
             x:Class="Noeud.Presentation.App"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Noeud.Presentation/Shared/Styles/Colors.axaml" />
        <StyleInclude Source="avares://Noeud.Presentation/Shared/Styles/Typography.axaml" />
        <StyleInclude Source="avares://Noeud.Presentation/Shared/Styles/Explorer.axaml" />
    </Application.Styles>
</Application>
