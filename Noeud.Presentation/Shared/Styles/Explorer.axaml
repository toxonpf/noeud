<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style Selector="StackPanel.ToolsBar">
        <Setter Property="Width" Value="40" />
        <Setter Property="Background" Value="{DynamicResource ChromeBrush}" />
    </Style>

    <Style Selector="Grid.TitleBar">
        <Setter Property="Height" Value="40" />
        <Setter Property="Background" Value="{DynamicResource ChromeBrush}" />
    </Style>

    <Style Selector="Grid.ExplorerTabsBlock">
        <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
    </Style>

    <Style Selector="Border.ExplorerTabIndicator">
        <Setter Property="Height" Value="40" />
        <Setter Property="Width" Value="50" />
        <Setter Property="Background" Value="{DynamicResource ExplorerIndicatorBrush}" />
        <Setter Property="IsHitTestVisible" Value="False" />
    </Style>

    <Style Selector="Border.ExplorerTab">
        <Setter Property="Width" Value="50" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="#00272727" />
    </Style>

    <Style Selector="Svg.ExplorerTabIcon">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style Selector="Grid.ExplorerPanel">
        <Setter Property="Background" Value="{DynamicResource ChromeBrush}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>

    <Style Selector="GridSplitter.ExplorerSplitter">
        <Setter Property="Background" Value="#00000000" />
        <Setter Property="Cursor" Value="SizeWestEast" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="ShowsPreview" Value="False" />
    </Style>

    <Style Selector="GridSplitter.ExplorerSplitter:pointerover">
        <Setter Property="Background" Value="#223A3A3A" />
    </Style>

    <Style Selector="GridSplitter.ExplorerSplitter:pressed">
        <Setter Property="Background" Value="#443A3A3A" />
    </Style>

    <Style Selector="Border.ExplorerFilesHost">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="Background" Value="{DynamicResource PanelSurfaceBrush}" />
        <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <Style Selector="StackPanel.ExplorerFilesContent">
        <Setter Property="Margin" Value="8,10,8,8" />
        <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <Style Selector="Grid.ExplorerUnderBar">
        <Setter Property="Height" Value="40" />
        <Setter Property="Background" Value="{DynamicResource PanelSurfaceBrush}" />
        <Setter Property="Margin" Value="0,2,0,0" />
    </Style>

    <Style Selector="TreeView.FilesTree">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="4,0,0,0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <Style Selector="TreeView.FilesTree ScrollViewer">
        <Setter Property="Background" Value="Transparent" />
    </Style>

    <Style Selector="TreeViewItem">
        <Setter Property="Foreground" Value="{DynamicResource ExplorerNodeBrush}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="MinHeight" Value="24" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
    </Style>

    <Style Selector="TreeViewItem:pointerover">
        <Setter Property="Background" Value="{DynamicResource ExplorerNodeHoverBrush}" />
    </Style>

    <Style Selector="TreeViewItem:selected">
        <Setter Property="Background" Value="{DynamicResource ExplorerNodeSelectedBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource ExplorerNodeSelectedForegroundBrush}" />
    </Style>

    <Style Selector="TreeViewItem:focus">
        <Setter Property="Background" Value="{DynamicResource ExplorerNodeSelectedBrush}" />
    </Style>

    <Style Selector="ToggleButton.ExplorerChevronButton">
        <Setter Property="Width" Value="14" />
        <Setter Property="Height" Value="14" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Template">
            <ControlTemplate>
                <Border Width="{TemplateBinding Width}"
                        Height="{TemplateBinding Height}"
                        Background="Transparent">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center" />
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="TextBlock.ExplorerChevronGlyph">
        <Setter Property="Text" Value="›" />
        <Setter Property="Foreground" Value="#8F8F8F" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="ToggleButton.ExplorerChevronButton:checked TextBlock.ExplorerChevronGlyph">
        <Setter Property="Text" Value="⌄" />
    </Style>

    <Style Selector="Border.ExplorerGuideLine">
        <Setter Property="Width" Value="1" />
        <Setter Property="Background" Value="#4A4A4A" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="Margin" Value="0,0,0,0" />
        <Setter Property="Opacity" Value="0.95" />
    </Style>

    <Style Selector="Border.ExplorerNodeContainer">
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="8,4,8,4" />
        <Setter Property="Margin" Value="0,1,0,1" />
    </Style>

    <Style Selector="DockPanel.EditorPanel">
        <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>
</Styles>
