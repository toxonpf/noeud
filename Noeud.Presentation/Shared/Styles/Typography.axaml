<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Style Selector="Window.AppShell">
        <Setter Property="Background" Value="{DynamicResource WindowBackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource WindowForegroundBrush}" />
        <Setter Property="FontFamily" Value="avares://Noeud.Presentation/Assets/Fonts/JetBrainsMono-ExtraLight.ttf#JetBrains Mono" />
    </Style>

    <Style Selector="TextBlock.ExplorerNodeText">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Foreground" Value="{DynamicResource ExplorerNodeBrush}" />
        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
</Styles>
