<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Styles.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#222222" />
        <SolidColorBrush x:Key="WindowForegroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="ChromeBrush" Color="#383838" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#1A1A1A" />
        <SolidColorBrush x:Key="PanelSurfaceBrush" Color="#272727" />
        <SolidColorBrush x:Key="ExplorerNodeBrush" Color="#D4D4D4" />
        <SolidColorBrush x:Key="ExplorerNodeHoverBrush" Color="#313131" />
        <SolidColorBrush x:Key="ExplorerNodeSelectedBrush" Color="#3A3A3A" />
        <SolidColorBrush x:Key="ExplorerNodeSelectedForegroundBrush" Color="#F1F1F1" />
        <SolidColorBrush x:Key="ExplorerIndicatorBrush" Color="#272727" />
    </Styles.Resources>
</Styles>
