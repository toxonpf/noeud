<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Noeud.Presentation.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1920" d:DesignHeight="1080"
        x:Class="Noeud.Presentation.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/img/avalonia-logo.ico"
        Title="Noeud.Presentation"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        SystemDecorations="None"
        Background="#222"
        Foreground="#fff"
        FontFamily="avares://Noeud.Presentation/Assets/Fonts/JetBrainsMono-ExtraLight.ttf#JetBrains Mono">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Window.Styles>
        <Style Selector=""></Style>

        <Style Selector="StackPanel.ToolsBar">
            <Setter Property="Width" Value="40" />
            <Setter Property="Background" Value="#383838" />
        </Style>

        <Style Selector="Grid.Header">
            <Setter Property="Height" Value="40" />
            <Setter Property="Background" Value="#383838" />
        </Style>


        <Style Selector="DockPanel.Editor">
            <Setter Property="Background" Value="#222" />
        </Style>

        <Style Selector="Grid.ExplorerPagesBlock">
            <Setter Property="Background" Value="#1a1a1a"></Setter>
        </Style>

        <Style Selector="Border.ExplorerPageSelectionIndicator">
            <Setter Property="Height" Value="40" />
            <Setter Property="Width" Value="50" />
            <Setter Property="Background" Value="#272727"></Setter>
        </Style>

        <Style Selector="Border.ExplorerPage">
            <Setter Property="Padding" Value="10"></Setter>
            <Setter Property="Width" Value="50"></Setter>
            <Setter Property="Cursor" Value="Hand"></Setter>
            <Setter Property="Background" Value="#00272727"></Setter>

            <Style Selector="^:nth-child(4)">
                <Setter Property="Padding" Value="9"></Setter>
            </Style>
            <Style Selector="^:nth-child(5)">
                <Setter Property="Padding" Value="7"></Setter>
                <Setter Property="Margin" Value="0, 0, 0, 1"></Setter>
            </Style>
        </Style>

        <Style Selector="Grid.Explorer">
            <Setter Property="Background" Value="#383838"></Setter>
        </Style>

        <Style Selector="Svg.ExplorerPageImg">
            <Setter Property="VerticalAlignment" Value="Center"></Setter>
            <Setter Property="HorizontalAlignment" Value="Center"></Setter>
        </Style>

        <Style Selector="Grid.Files">
            <Setter Property="Width" Value="250" />
            <Setter Property="Background" Value="#272727" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>

        <Style Selector="Grid.UnderBar">
            <Setter Property="Height" Value="40" />
            <Setter Property="Background" Value="#272727" />
            <Setter Property="Margin" Value="0,2,0,0" />
        </Style>

        <Style Selector="StackPanel.FilesExp">
            <Setter Property="Margin" Value="8,10,8,8" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>

        <Style Selector="TreeView.FilesTree">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="4,0,0,0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="ClipToBounds" Value="True" />
        </Style>

        <Style Selector="TreeView.FilesTree ScrollViewer">
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style Selector="TreeViewItem">
            <Setter Property="Foreground" Value="#D4D4D4" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="Medium" />
            <Setter Property="MinHeight" Value="24" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
        </Style>

        <Style Selector="TreeViewItem:pointerover">
            <Setter Property="Background" Value="#313131" />
        </Style>

        <Style Selector="TreeViewItem:selected">
            <Setter Property="Background" Value="#3A3A3A" />
            <Setter Property="Foreground" Value="#F1F1F1" />
        </Style>

        <Style Selector="TreeViewItem:focus">
            <Setter Property="Background" Value="#3A3A3A" />
        </Style>

        <Style Selector="ToggleButton.ExplorerChevronButton">
            <Setter Property="Width" Value="14" />
            <Setter Property="Height" Value="14" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            Background="Transparent">
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>

        <Style Selector="TextBlock.ExplorerChevronGlyph">
            <Setter Property="Foreground" Value="#8F8F8F" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style Selector="ToggleButton.ExplorerChevronButton:checked TextBlock.ExplorerChevronGlyph">
            <Setter Property="Text" Value="⌄" />
        </Style>

        <Style Selector="TextBlock.ExplorerNodeText">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="#D4D4D4" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style Selector="Border.ExplorerGuideLine">
            <Setter Property="Width" Value="1" />
            <Setter Property="Background" Value="#4A4A4A" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Margin" Value="0,0,0,0" />
            <Setter Property="Opacity" Value="0.95" />
        </Style>

    </Window.Styles>

    <Grid Classes="Main" ColumnDefinitions="Auto, *">
        <!-- Основной блок со всем интерфейсом -->

        <StackPanel Grid.Column="0" Classes="ToolsBar">
            <!-- Блок слева с инструментами, плагинами и тд. -->

        </StackPanel>
        <Grid Grid.Column="1" RowDefinitions="Auto, *">
            <!-- Блок содержащий Header и основную рабочую область -->

            <Grid Classes="Header" Grid.Row="0" ColumnDefinitions="Auto,Auto,Auto"
                  PointerPressed="InputElement_OnPointerPressed">

                <Grid Classes="ExplorerPagesBlock" x:Name="ExplorerPagesBlock" Grid.Column="0"
                      ColumnDefinitions="*, *, *, *">
                    <Border Classes="ExplorerPageSelectionIndicator"
                            x:Name="ExplorerPageSelectionIndicator"
                            Grid.Column="0"
                            IsHitTestVisible="False">
                        <!-- каретка показывающая какой режим у проводника -->

                        <Border.RenderTransform>
                            <TranslateTransform X="0">
                                <TranslateTransform.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="X" Duration="0:0:0.25" Easing="QuarticEaseOut" />
                                    </Transitions>
                                </TranslateTransform.Transitions>
                            </TranslateTransform>
                        </Border.RenderTransform>
                    </Border>

                    <Border Classes="ExplorerPage" x:Name="ExplorerPageButtonHide" Grid.Column="0"
                            PointerPressed="ExplorerPageButton_OnPointerPressed">
                        <Svg
                            Classes="ExplorerPageImg"
                            Path="avares://Noeud.Presentation/Assets/img/buttonHide.svg" />
                    </Border>

                    <Border Classes="ExplorerPage" x:Name="ExplorerPageButtonExp" Grid.Column="1"
                            PointerPressed="ExplorerPageButton_OnPointerPressed">
                        <Svg
                            Classes="ExplorerPageImg"
                            Path="avares://Noeud.Presentation/Assets/img/buttonExp.svg" />
                    </Border>

                    <Border Classes="ExplorerPage" x:Name="ExplorerPageButtonSearch" Grid.Column="2"
                            PointerPressed="ExplorerPageButton_OnPointerPressed">
                        <Svg
                            Classes="ExplorerPageImg"
                            Path="avares://Noeud.Presentation/Assets/img/buttonSearch.svg" />
                    </Border>

                    <Border Classes="ExplorerPage" x:Name="ExplorerPageButtonCanv" Grid.Column="3"
                            PointerPressed="ExplorerPageButton_OnPointerPressed">
                        <Svg
                            Classes="ExplorerPageImg"
                            Path="avares://Noeud.Presentation/Assets/img/buttonCanv.svg" />
                    </Border>
                </Grid>
            </Grid>
            <Grid Grid.Row="1" ColumnDefinitions="Auto, *">
                <!-- Блок содержащий проводник и редактор -->

                <Grid Classes="Explorer" Grid.Column="0" RowDefinitions="*, Auto">
                    <!-- Блок содержащий проводник и нижний бар -->

                    <Grid Classes="Files" Grid.Row="0" RowDefinitions="*">
                        <StackPanel Classes="FilesExp">
                            <TreeView Classes="FilesTree"
                                      ItemsSource="{Binding ExplorerItems}"
                                      SelectedItem="{Binding SelectedExplorerItem, Mode=TwoWay}">
                                <TreeView.ItemContainerTheme>
                                    <ControlTheme TargetType="TreeViewItem">
                                        <Setter Property="Template">
                                            <ControlTemplate>
                                                <Grid RowDefinitions="Auto,*"
                                                      ColumnDefinitions="16,*">
                                                    <ToggleButton Classes="ExplorerChevronButton"
                                                                  Grid.Row="0"
                                                                  Grid.Column="0"
                                                                  Focusable="False"
                                                                  IsVisible="{ReflectionBinding Header.IsDirectory, RelativeSource={RelativeSource TemplatedParent}}"
                                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                                        <TextBlock Classes="ExplorerChevronGlyph"
                                                                   Text="›" />
                                                    </ToggleButton>

                                                    <Border Grid.Row="0"
                                                            Grid.Column="1"
                                                            CornerRadius="4"
                                                            Padding="8,4,8,4"
                                                            Margin="0,1,0,1"
                                                            Background="{TemplateBinding Background}">
                                                        <ContentPresenter Name="PART_HeaderPresenter"
                                                                          Content="{TemplateBinding Header}"
                                                                          ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                                          Foreground="{TemplateBinding Foreground}" />
                                                    </Border>

                                                    <Border Classes="ExplorerGuideLine"
                                                            Grid.Row="1"
                                                            Grid.Column="0"
                                                            IsVisible="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}" />

                                                    <ItemsPresenter Name="PART_ItemsPresenter"
                                                                    Grid.Row="1"
                                                                    Grid.Column="1"
                                                                    IsVisible="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}" />
                                                </Grid>
                                            </ControlTemplate>
                                        </Setter>
                                    </ControlTheme>
                                </TreeView.ItemContainerTheme>

                                <TreeView.ItemTemplate>
                                    <TreeDataTemplate x:DataType="vm:ExplorerItemViewModel"
                                                      ItemsSource="{Binding Children}">
                                        <TextBlock Classes="ExplorerNodeText"
                                                   Text="{Binding Name}" />
                                    </TreeDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </StackPanel>
                    </Grid>
                    <Grid Classes="UnderBar" Grid.Row="1">

                    </Grid>
                </Grid>
                <DockPanel Classes="Editor" Grid.Column="1">

                </DockPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
