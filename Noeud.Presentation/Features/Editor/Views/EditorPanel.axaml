<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:editorVm="using:Noeud.Presentation.Features.Editor.ViewModels"
             mc:Ignorable="d"
             x:Class="Noeud.Presentation.Features.Editor.Views.EditorPanel"
             x:DataType="editorVm:EditorPanelViewModel">

    <Design.DataContext>
        <editorVm:EditorPanelViewModel />
    </Design.DataContext>

    <DockPanel Classes="EditorPanel" />
</UserControl>
